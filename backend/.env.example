# ==========================================
# Application & Security
# ==========================================
# 12-character alphanumeric key required for all API requests
API_KEY=Your12CharKey

DEBUG=false
SQL_ECHO=false

# ==========================================
# Database
# ==========================================
# Defaults to sqlite:///app.db if omitted
DATABASE_URL=sqlite:///app.db

# ==========================================
# Business Configuration
# ==========================================
# Replace with your actual Google Business review link
GOOGLE_REVIEW_URL=https://g.page/r/YOUR_BUSINESS_LINK/review

# Suppression window in days (default: 90)
SUPPRESSION_WINDOW_DAYS=90

# ==========================================
# Twilio (SMS Integration)
# ==========================================
# Leave empty to run in SIMULATION mode (logs SMS to console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# ==========================================
# Resend (Email Integration)
# ==========================================
# Leave empty to run in SIMULATION mode (logs emails to console)
RESEND_API_KEY=
# Destination email for dissatisfaction alerts
RESEND_ALERT_EMAIL=alerts@yourdomain.com

# ==========================================
# AI / LLM (HuggingFace Router via OpenAI-compatible client)
# ==========================================
# HuggingFace API Token. Leave empty to use SIMULATION mode.
OPENAI_API_KEY=hf_YourTokenHere